# MLPerf Test Configuration
# This file contains default configuration values for the MLPerf test framework
#
# EXECUTION FLOW:
# Phase 1 (Setup - Before "RUNNING TEST..."):
#   - Steps 0-5: Interactive config, Docker validation, dataset validation,
#                container launch, calibration check, initialization
# Phase 2 (Benchmark - During "RUNNING TEST..."):
#   - Step 6: MLPerf benchmark execution (runs in GpuStressProcess)
# Phase 3 (Results - After test execution):
#   - Step 7: Results presentation and PASS/FAIL determination
#
# All configuration below can be customized without modifying Python code.

# Docker Configuration
DOCKER_IMAGE=intel/intel-optimized-pytorch:mlperf-inference-6.0-llama_xpu
CONTAINER_NAME=mlperf_benchmark_container

# Default Directory Paths (will be expanded to /home/{user}/)
# The {user} placeholder will be automatically replaced with the current user
DATA_DIR=/home/{user}/data
MODEL_DIR=/home/{user}/model/.llama/checkpoints
LOG_DIR=/home/{user}/logs

# Proxy Configuration
# Set your corporate/network proxy here, or leave empty if not needed.
# These are passed into Docker containers and subprocess calls.
HTTP_PROXY=
HTTPS_PROXY=

# Scripts Inside Docker Image (paths in container)
CALIBRATION_SCRIPT=bash scripts/run_calibration.sh
INIT_SCRIPT=/workspace/initialize.sh

# Llama3.1-8B Calibrated Model Validation
# Calibrated model subdirectory under /model/ in container
LLAMA3_CALIBRATED_SUBDIR=Llama-3.1-8B-Instruct-autoround-w4g-1-iters512-xpu
LLAMA3_CALIB_FILE1_NAME=chat_template.jinja
LLAMA3_CALIB_FILE2_NAME=config.json
LLAMA3_CALIB_FILE3_NAME=generation_config.json
LLAMA3_CALIB_FILE4_NAME=model.safetensors.index.json
LLAMA3_CALIB_FILE5_NAME=quantization_config.json
LLAMA3_CALIB_FILE6_NAME=special_tokens_map.json
LLAMA3_CALIB_FILE7_NAME=tokenizer_config.json
LLAMA3_CALIB_FILE8_NAME=tokenizer.json
# model-NNNNN-of-NNNNN.safetensors shards are validated dynamically (any count accepted)

# Default Benchmark Script (will be overridden by interactive selection)
BENCHMARK_SCRIPT=SCENARIO=Offline MODE=Performance bash /workspace/run_mlperf.sh

# Benchmark Script Names
BENCHMARK_SCRIPT_LLAMA2_70B=run_mlperf.sh
BENCHMARK_SCRIPT_LLAMA3_1_8B=run_mlperf.sh

# Default Benchmark Configuration
DEFAULT_MODEL_NAME=TechxGenus/Meta-Llama-3-8B-GPTQ
DEFAULT_MAX_TOKENS=128
DEFAULT_INPUT_LENGTH=64
DEFAULT_CONCURRENCY=2

# Temporary Hacks Configuration
# Hack 2: Llama2-70B model name correction
HACK2_FILE=/workspace/model_init/llama2-70b/init_env_shared
HACK2_OLD_VALUE=export MODEL_NAME="/model/llama2-gptq-w4g-1b8kv"
HACK2_NEW_VALUE=export MODEL_NAME="/model/Llama-2-70b-chat-hf-gptq-w4g-1kv"

# Hack 3: Llama2-70B PP and MAX_NUM_BATCHED_TOKENS
HACK3_FILE=/workspace/model_init/llama2-70b/init_env_offline
HACK3_PP_OLD=export PP=4
HACK3_PP_NEW=export PP=2
HACK3_TOKENS_OLD=export MAX_NUM_BATCHED_TOKENS=256
HACK3_TOKENS_NEW=export MAX_NUM_BATCHED_TOKENS=192

# Hack 4: Llama2-70B GPU memory utilization
HACK4_FILE=/workspace/model_init/llama2-70b/init_env_offline
HACK4_INSERT_AFTER=if (( XPU_COUNT > 0 )); then
HACK4_NEW_LINE=    export GPU_MEMORY_UTILIZATION=0.99

